# ============================================================
# ConsentsPro — Variables de entorno
# Copiar a .env.local y rellenar valores reales
# NUNCA commitear .env.local — está en .gitignore
# ============================================================

# ── API URL (backend Express en Railway) ────────────────────
VITE_API_URL=https://tu-proyecto.railway.app/api

# ── Anthropic (traducción automática) ───────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── App ─────────────────────────────────────────────────────
VITE_APP_URL=https://tu-proyecto.railway.app
APP_URL=https://tu-proyecto.railway.app

# ============================================================
# Variables del backend (Railway)
# ============================================================

# Base de datos Railway PostgreSQL
DATABASE_URL=postgresql://user:password@host.railway.internal:5432/railway

# Redis Railway (sesiones y colas)
# REDIS_URL=redis://default:password@host.railway.internal:6379

# JWT para sesiones Express (generar con: openssl rand -hex 32)
JWT_SECRET=cambia-esto-por-un-secreto-aleatorio-de-64-chars

# Puerto servidor Railway
PORT=3001
NODE_ENV=production

# Stripe (facturación de planes — Configuración > Planes Suscripción)
STRIPE_SECRET_KEY=sk_live_...
# Signing secret del endpoint de webhook, generado al crearlo en el
# Dashboard de Stripe (Developers > Webhooks): https://.../api/billing/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
# URL pública del propio backend (no la del frontend/APP_URL) — se usa en
# los enlaces de los emails de facturación (cancelar, portal de pago,
# reactivar). Opcional: si no se define, se usa RAILWAY_PUBLIC_DOMAIN, que
# Railway inyecta automáticamente.
# API_URL=https://tu-backend-production.up.railway.app
# Email que recibe un aviso cada vez que se contrata un plan nuevo.
# BILLING_NOTIFICATION_EMAIL=tucorreo@ejemplo.com

# ============================================================
# Bono IA — sistema de crédito prepago por clínica (Anthropic/
# OpenRouter, Retell, YCloud) y enrutamiento de WhatsApp
# ============================================================

# Emails transaccionales (avisos de saldo bajo, saldo de proveedor bajo)
RESEND_API_KEY=re_...
# RESEND_FROM=notificaciones@tu-dominio.com

# Proveedor de IA activo para el agente de WhatsApp (Anthropic u
# OpenRouter) — se elige desde Configuración > Claves (superadmin), pero
# cada uno necesita su clave aquí si se va a usar.
# ANTHROPIC_API_KEY ya definida arriba (traducción automática y Bono IA comparten clave)
# OPENROUTER_API_KEY=sk-or-v1-...

# Número único de WhatsApp (YCloud) compartido por TODAS las clínicas —
# solo dígitos, sin '+'. Se usa para construir los enlaces directos por
# clínica (wa.me/<numero>?text=CLINICA_<codigo>).
# YCLOUD_WA_NUMBER=34900000000

# Firma HMAC de los webhooks de Retell (Dashboard > Webhooks). Si no se
# define, los webhooks de Retell se aceptan sin verificar firma (aviso en
# consola) — definirla antes de producción.
# RETELL_WEBHOOK_SECRET=...

# Buzón interno del equipo de ConsentsPro que recibe la alarma si el saldo
# real de la cuenta de YCloud (la que paga ConsentsPro, no el bono de
# ninguna clínica) baja del umbral configurado en Superadmin.
# CONSENTSPRO_TEAM_EMAIL=equipo@consentspro.com
