# ============================================================
# ConsentsPro — Variables de entorno
# Copiar a .env.local y rellenar valores reales
# NUNCA commitear .env.local — está en .gitignore
# ============================================================

# ── Supabase (obligatorio Fase 1) ───────────────────────────
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service key solo para Netlify Functions (no exponer al frontend)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── API URL (controla Netlify vs Railway) ───────────────────
# Fase 1 — Netlify Functions:
VITE_API_URL=https://tu-proyecto.netlify.app/.netlify/functions
# Fase 2 — Railway (comentar la línea anterior y descomentar esta):
# VITE_API_URL=https://tu-proyecto.railway.app/api

# ── Anthropic (traducción automática) ───────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── App ─────────────────────────────────────────────────────
VITE_APP_URL=https://tu-proyecto.netlify.app

# ============================================================
# Variables RAILWAY (comentadas — solo necesarias en Fase 2)
# ============================================================

# Base de datos Railway PostgreSQL
# DATABASE_URL=postgresql://user:password@host.railway.internal:5432/railway

# Redis Railway (sesiones y colas)
# REDIS_URL=redis://default:password@host.railway.internal:6379

# JWT para sesiones Express (generar con: openssl rand -hex 32)
# JWT_SECRET=cambia-esto-por-un-secreto-aleatorio-de-64-chars

# Puerto servidor Railway
# PORT=3001
# NODE_ENV=production
